# Webnovel Writer example configuration
# Copy this file to .env and fill in the values you actually use.
# Never commit a real API key.

# ==================== Writing Model ====================
# Recommended default: Codex CLI
WEBNOVEL_LLM_PROVIDER=codex-cli
WEBNOVEL_CODEX_BIN=codex.cmd

# Optional API path for ChatGPT-style models.
# Switch the provider only when you want the writing workflow to use API mode.
# WEBNOVEL_LLM_PROVIDER=openai-compatible
# WEBNOVEL_LLM_BASE_URL=https://api.openai.com/v1
# WEBNOVEL_LLM_MODEL=gpt-5.4
# WEBNOVEL_LLM_API_KEY=your_llm_api_key_here

# Optional runtime tuning
# WEBNOVEL_LLM_TIMEOUT_MS=120000
# WEBNOVEL_LLM_TEMPERATURE=0.1

# ==================== RAG (SiliconFlow) ====================
WEBNOVEL_RAG_BASE_URL=https://api.siliconflow.cn/v1
WEBNOVEL_RAG_API_KEY=your_siliconflow_api_key_here
WEBNOVEL_RAG_EMBED_MODEL=BAAI/bge-m3
WEBNOVEL_RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
WEBNOVEL_RAG_MAX_RETRIES=6
WEBNOVEL_RAG_RETRY_INITIAL_DELAY_MS=500
WEBNOVEL_RAG_RETRY_MAX_DELAY_MS=8000

# ==================== Optional ====================
# WEBNOVEL_PROJECT_ROOT=D:\path\to\your\novel
